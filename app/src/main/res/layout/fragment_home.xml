<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0F">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="52dp"
        android:paddingBottom="20dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CROCODILE"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:letterSpacing="0.15"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/tvIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● STANDBY"
            android:textColor="#555555"
            android:textSize="11sp"
            android:letterSpacing="0.1"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1F1F2E"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="80dp">

            <!-- HOW IT WORKS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HOW IT WORKS"
                android:textColor="#555566"
                android:textSize="10sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                app:cardBackgroundColor="#13131A"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/tutorialPager"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>
            </androidx.cardview.widget.CardView>

            <com.tbuonomo.viewpagerdotsindicator.DotsIndicator
                android:id="@+id/tutorialDots"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                app:dotsColor="#A78BFA"
                app:dotsSize="6dp"
                app:dotsSpacing="4dp"
                app:dotsCornerRadius="8dp"
                app:selectedDotColor="#A78BFA"
                app:progressMode="true"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="28dp">
                <Button
                    android:id="@+id/btnPrev"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="이전"
                    android:textSize="12sp"
                    android:textColor="#888899"
                    android:backgroundTint="#1E1E2E"/>
                <Button
                    android:id="@+id/btnNext"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:text="다음"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#A78BFA"/>
            </LinearLayout>

            <!-- 주요 기능 그리드 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="주요 기능"
                android:textColor="#555566"
                android:textSize="10sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:id="@+id/featureOndeviceAi"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/bg_feature_item"
                    android:clickable="true"
                    android:focusable="true">
                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_ondevice_icon"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="🧠"
                            android:textSize="20sp"/>
                    </FrameLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="온디바이스 AI"
                        android:textColor="#E0E0F0"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="통화 내용은 기기 밖으로 나가지 않아요"
                        android:textColor="#555566"
                        android:textSize="10sp"
                        android:lineSpacingMultiplier="1.4"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/featureSimBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/bg_feature_item"
                    android:clickable="true"
                    android:focusable="true">
                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_simbox_icon"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="📡"
                            android:textSize="20sp"/>
                    </FrameLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SIM Box 탐지"
                        android:textColor="#E0E0F0"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="불법 중계기를 실시간으로 감지해요"
                        android:textColor="#555566"
                        android:textSize="10sp"
                        android:lineSpacingMultiplier="1.4"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/featureAiCrocodile"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/bg_feature_item"
                    android:clickable="true"
                    android:focusable="true">
                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_aicroc_icon"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="🤖"
                            android:textSize="20sp"/>
                    </FrameLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI 크로커다일"
                        android:textColor="#E0E0F0"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI가 대응 스크립트를 속삭여줘요"
                        android:textColor="#555566"
                        android:textSize="10sp"
                        android:lineSpacingMultiplier="1.4"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/featureUrlCheck"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/bg_feature_item"
                    android:clickable="true"
                    android:focusable="true">
                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_url_icon"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="🔗"
                            android:textSize="20sp"/>
                    </FrameLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="URL 검사"
                        android:textColor="#E0E0F0"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="스미싱 악성 링크를 즉시 검사해요"
                        android:textColor="#555566"
                        android:textSize="10sp"
                        android:lineSpacingMultiplier="1.4"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>